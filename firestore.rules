rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funciones de utilidad
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin' ||
        request.auth.token.email == 'admin@zyra.com'
      );
    }

    // Reglas para Usuarios
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Reglas para Notificaciones
    match /notifications/{notifId} {
      // Permitir lectura si el usuario es admin o si el documento le pertenece
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      // Permitir creación si el usuario es admin o si se asigna a sí mismo (para logs operativos)
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Reglas para Proyectos
    match /proyectos/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reglas para Equipos (Teams)
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reglas para Reportes
    match /reports/{reportId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.employeeId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // Reglas para catálogos
    match /materiales/{matId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /checklist_servicio/{checkId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /clientes/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}