
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Función robusta para verificar rol de administrador
    function isAdmin() { 
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin'; 
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /notifications/{notifId} {
      // Permitir lectura si el documento pertenece al usuario o si es admin
      // La condición de listado se satisface si la consulta está filtrada por userId
      allow read: if isSignedIn() && (
        (resource == null) || 
        (resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /proyectos/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }
    
    match /materiales/{matId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /checklist_servicio/{checkId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /clientes/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
