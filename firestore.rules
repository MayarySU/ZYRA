rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Simplified for reliability: explicitly trust the root admin email
      return isSignedIn() && (
        request.auth.token.email == 'admin@zyra.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin')
      );
    }

    // --- User Rules ---
    match /users/{userId} {
      allow read, get, list: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /user_activity/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // --- Business Entities ---
    match /clientes/{clientId} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /materiales/{materialId} {
      allow read, get, list: if isSignedIn();
      // Admin puede crear/eliminar. Empleados autenticados pueden actualizar stock (decremento).
      allow create, delete: if isAdmin();
      allow update: if isSignedIn();
    }
    
    match /proyectos/{projectId} {
      allow read, get, list: if isSignedIn();
      // Admin puede crear/eliminar proyectos. Empleados pueden actualizar (checklist, estado, stock).
      allow create, delete: if isAdmin();
      allow update: if isSignedIn();
    }

    match /teams/{teamId} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Operational Rules ---
    match /reports/{reportId} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /checklist_servicio/{docId} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /activity_logs/{logId} {
      // Permissive read for now to fix the Profile Page crashes
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /puntos_historial/{id} {
      allow read, get, list: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}