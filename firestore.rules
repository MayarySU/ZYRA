
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funciones de utilidad
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        (exists(userPath) && get(userPath).data.rol == 'admin') ||
        request.auth.token.email == 'admin@zyra.com'
      );
    }

    // Reglas para Usuarios
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Reglas para Notificaciones
    match /notifications/{notifId} {
      // Regla de lectura individual
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      // Regla de listado: Fundamental para que el motor de consultas valide el filtro por userId
      allow list: if isSignedIn() && (isAdmin() || (request.query.limit <= 50));
      
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Reglas para Proyectos
    match /proyectos/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reglas para Equipos (Teams)
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reglas para Reportes
    match /reports/{reportId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.employeeId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // Reglas para catálogos
    match /materiales/{matId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /checklist_servicio/{checkId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /clientes/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
