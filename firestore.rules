
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin'; 
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /notifications/{notifId} {
      // Separamos get y list para mejorar la evaluación de consultas filtradas
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.userId);
      
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /proyectos/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && request.auth.uid in resource.data.members)
      );
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow get: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.employeeId);
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    match /materiales/{matId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /checklist_servicio/{checkId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /clientes/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
