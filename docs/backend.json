
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Información de perfil del empleado y datos de gamificación.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nombre": { "type": "string" },
        "rol": { "type": "string", "enum": ["admin", "employee"] },
        "nivel": { "type": "number" },
        "puntos": { "type": "number" },
        "racha": { "type": "number" },
        "logros": { "type": "array", "items": { "type": "string" } },
        "projectStatus": {
          "type": "object",
          "description": "Estado del checklist por proyecto.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "checklist_completado": { "type": "boolean" },
              "timestamp_inicio": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["uid", "nombre", "rol"]
    },
    "Project": {
      "title": "Project Details",
      "description": "Información general de una obra o proyecto solar.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "cliente": { "type": "string" },
        "estado": { "type": "string", "enum": ["ejecucion", "validacion", "finalizado"] },
        "descripcion": { "type": "string" },
        "ubicacion": { "type": "string" },
        "progreso": { "type": "number" },
        "miembros": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" }
      },
      "required": ["nombre", "cliente", "estado"]
    },
    "ProjectMaterial": {
      "title": "Assigned Material",
      "description": "Material asignado a un proyecto para verificación del empleado.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "cantidad_esperada": { "type": "number" },
        "estado_verificacion": { "type": "boolean" },
        "nota_faltante": { "type": "string" }
      }
    },
    "InventoryHistory": {
      "title": "Inventory Log",
      "description": "Registro de salida de materiales a obra.",
      "type": "object",
      "properties": {
        "mensaje": { "type": "string" },
        "empleadoID": { "type": "string" },
        "empleadoNombre": { "type": "string" },
        "proyectoID": { "type": "string" },
        "fecha": { "type": "string", "format": "date-time" },
        "detalles_materiales": { "type": "array", "items": { "$ref": "#/entities/ProjectMaterial" } }
      }
    },
    "ProjectChecklist": {
      "title": "Initial Checklist",
      "description": "Validación de seguridad y herramientas antes de iniciar la jornada.",
      "type": "object",
      "properties": {
        "epp_completo": { "type": "boolean" },
        "herramientas_listas": { "type": "boolean" },
        "seguridad_area": { "type": "boolean" },
        "foto_evidencia_inicio": { "type": "string" },
        "empleadoID": { "type": "string" },
        "fecha": { "type": "string", "format": "date-time" }
      },
      "required": ["epp_completo", "herramientas_listas", "seguridad_area", "empleadoID"]
    },
    "Report": {
      "title": "Operational Report",
      "description": "Reportes diarios generados por los empleados.",
      "type": "object",
      "properties": {
        "fecha": { "type": "string", "format": "date-time" },
        "empleadoID": { "type": "string" },
        "contenido": { "type": "string" },
        "highlights": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "puntosOtorgados": { "type": "number" },
        "proyectoID": { "type": "string" }
      },
      "required": ["fecha", "empleadoID", "contenido"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Colección de perfiles de usuario."
    },
    "/proyectos/{projectId}": {
      "schema": "Project",
      "description": "Documento principal del proyecto."
    },
    "/proyectos/{projectId}/checklist_inicial/{checklistId}": {
      "schema": "ProjectChecklist",
      "description": "Subcolección de validaciones iniciales por jornada."
    },
    "/proyectos/{projectId}/materiales_asignados/{materialId}": {
      "schema": "ProjectMaterial",
      "description": "Materiales asignados por el admin."
    },
    "/reportes/{reportId}": {
      "schema": "Report",
      "description": "Colección de reportes operacionales."
    },
    "/historial_inventario/{logId}": {
      "schema": "InventoryHistory",
      "description": "Log global de movimientos de inventario."
    }
  }
}
